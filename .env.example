# Scolta AI Search Configuration for WordPress
#
# Set the API key via environment variable (recommended):
SCOLTA_API_KEY=
#
# Or define in wp-config.php:
#   define('SCOLTA_API_KEY', 'sk-ant-...');
#
# All other settings are managed via Settings > Scolta in the WordPress admin.
# The wp_options key 'scolta_settings' stores all configuration as a serialized array.
#
# Available settings (and their defaults):
#   ai_provider: 'anthropic'          - AI provider ('anthropic' or 'openai')
#   ai_model: 'claude-sonnet-4-5-20250514' - Model identifier
#   ai_base_url: ''                   - Custom API endpoint
#   ai_expand_query: true             - Enable AI query expansion
#   ai_summarize: true                - Enable AI summarization
#   max_follow_ups: 3                 - Max follow-up questions per session
#   site_name: ''                     - Site name for AI prompts (defaults to bloginfo)
#   site_description: 'website'       - Site description for AI context
#   post_types: ['post', 'page']      - Post types to index
#   pagefind_binary: 'pagefind'       - Pagefind binary path
#   build_dir: '{WP_CONTENT_DIR}/scolta-build'  - HTML export directory
#   output_dir: '{ABSPATH}/scolta-pagefind'      - Pagefind index directory
#   cache_ttl: 2592000                - AI cache TTL in seconds (30 days)
#   title_match_boost: 1.0            - Scoring: title match boost
#   content_match_boost: 0.4          - Scoring: content match boost
#   recency_boost_max: 0.5            - Scoring: recency boost
#   results_per_page: 10              - Display: results per page
#   excerpt_length: 300               - Display: excerpt character limit
