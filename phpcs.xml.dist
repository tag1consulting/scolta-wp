<?xml version="1.0"?>
<ruleset name="Scolta WordPress">
  <description>WordPress coding standards for Scolta plugin</description>
  <arg name="extensions" value="php"/>
  <arg name="colors"/>
  <arg value="sp"/>

  <file>includes</file>
  <file>cli</file>
  <file>admin</file>
  <file>scolta.php</file>
  <file>uninstall.php</file>

  <rule ref="WordPress-Extra"/>

  <!-- Docblock standards on the class directories. scolta.php and
       uninstall.php are procedural bootstrap files with hook closures;
       WordPress-Docs is class/method-oriented, so they stay out. -->
  <rule ref="WordPress-Docs">
    <exclude-pattern>scolta\.php</exclude-pattern>
    <exclude-pattern>uninstall\.php</exclude-pattern>
  </rule>

  <!-- Must match the plugin header / readme.txt "Requires at least" — the
       code requires 6.1 (wp_cache_flush_group()). -->
  <config name="minimum_supported_wp_version" value="6.1"/>
  <config name="text_domain" value="scolta-ai-search"/>

  <!-- Allow long lines in tests and admin HTML templates -->
  <rule ref="Generic.Files.LineLength">
    <exclude-pattern>tests/*</exclude-pattern>
  </rule>
  <!-- The soft line-length warning is churn-only: the hard MaxExceeded
       limit stays enforced (below), and rewrapping ~400 legacy lines
       would bury real diffs. -->
  <rule ref="Generic.Files.LineLength.TooLong">
    <exclude-pattern>*</exclude-pattern>
  </rule>
  <!-- Admin and CLI have HTML-heavy rendering code; relax hard line limit -->
  <rule ref="Generic.Files.LineLength.MaxExceeded">
    <exclude-pattern>admin/*</exclude-pattern>
    <exclude-pattern>cli/*</exclude-pattern>
  </rule>

  <!-- WordPress hook, REST/shortcode, WP-CLI command, and interface
       signatures are fixed by their contracts; those callbacks legitimately
       ignore trailing parameters. Scoped to the files that actually hold such
       callbacks rather than excluded repo-wide, so genuinely unused params
       elsewhere still surface. -->
  <rule ref="Generic.CodeAnalysis.UnusedFunctionParameter">
    <exclude-pattern>scolta\.php</exclude-pattern>
    <exclude-pattern>cli/*</exclude-pattern>
    <exclude-pattern>includes/class-scolta-rest-api\.php</exclude-pattern>
    <exclude-pattern>includes/class-scolta-shortcode\.php</exclude-pattern>
    <exclude-pattern>includes/class-scolta-build-status-progress-reporter\.php</exclude-pattern>
    <exclude-pattern>includes/class-scolta-amazee-budget-handler\.php</exclude-pattern>
  </rule>

  <!--
    Yoda conditions are a WP style preference, not a code-quality rule.
    Scolta interfaces with PSR-4 scolta-php which uses standard conditions.
    Enforcing Yoda would require diverging from scolta-php conventions.
  -->
  <rule ref="WordPress.PHP.YodaConditions">
    <exclude-pattern>*</exclude-pattern>
  </rule>

  <!--
    ini_set('display_errors') is intentional in CLI commands: managed hosting
    (WP Engine, Kinsta) echoes PHP warnings mid-JSON output, breaking clients.
    The CLI suppresses display_errors for the duration of each command.
    See: CliValidationTest::test_public_commands_suppress_display_errors()
  -->
  <rule ref="WordPress.PHP.IniSet">
    <exclude-pattern>cli/*</exclude-pattern>
  </rule>

  <!--
    Properties and variables that interface with scolta-php (PSR-4) use
    camelCase to match their counterparts. Renaming would break the interface.
  -->
  <rule ref="WordPress.NamingConventions.ValidVariableName.PropertyNotSnakeCase">
    <exclude-pattern>*</exclude-pattern>
  </rule>
  <rule ref="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase">
    <exclude-pattern>includes/*</exclude-pattern>
    <exclude-pattern>cli/*</exclude-pattern>
    <exclude-pattern>admin/*</exclude-pattern>
  </rule>
  <rule ref="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase">
    <exclude-pattern>*</exclude-pattern>
  </rule>
</ruleset>
