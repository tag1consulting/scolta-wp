{
    "name": "tag1/scolta-wp",
    "version": "0.2.0",
    "description": "Scolta AI Search for WordPress — zero-infrastructure AI-powered search with Pagefind",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Tag1 Consulting",
            "homepage": "https://www.tag1.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "tag1/scolta-php": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "wp-coding-standards/wpcs": "^3.0",
        "yoast/phpunit-polyfills": "^2.0|^3.0"
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "format": "phpcbf",
        "validate-release": "php scripts/validate-release.php"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../scolta-php"
        }
    ],
    "autoload": {
        "classmap": [
            "includes/",
            "admin/",
            "cli/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "installer-name": "scolta"
    }
}
