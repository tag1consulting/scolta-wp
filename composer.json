{
    "name": "tag1/scolta-wp",
    "version": "1.0.0-rc2",
    "description": "Scolta AI Search for WordPress \u2014 zero-infrastructure AI-powered search with Pagefind",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Tag1 Consulting",
            "homepage": "https://www.tag1.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "tag1/scolta-php": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "wp-coding-standards/wpcs": "^3.0",
        "yoast/phpunit-polyfills": "^2.0|^3.0"
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "format": "phpcbf",
        "validate-release": "php scripts/validate-release.php",
        "post-install-cmd": [
            "[ -f vendor/tag1/scolta-php/assets/js/scolta.js ] && cp vendor/tag1/scolta-php/assets/js/scolta.js assets/js/scolta.js || true"
        ],
        "post-update-cmd": [
            "[ -f vendor/tag1/scolta-php/assets/js/scolta.js ] && cp vendor/tag1/scolta-php/assets/js/scolta.js assets/js/scolta.js || true"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/tag1consulting/scolta-php"
        }
    ],
    "autoload": {
        "classmap": [
            "includes/",
            "admin/",
            "cli/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "audit": {
            "ignore": [
                "PKSA-5jz8-6tcw-pbk4",
                "PKSA-z3gr-8qht-p93v"
            ]
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "installer-name": "scolta"
    }
}
