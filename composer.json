{
    "name": "tag1/scolta-wp",
    "description": "Scolta AI Search for WordPress — zero-infrastructure AI-powered search with Pagefind",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Tag1 Consulting",
            "homepage": "https://www.tag1.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "tag1/scolta-php": "^0.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "wp-cli/wp-cli": "^2.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "classmap": [
            "includes/",
            "admin/",
            "cli/"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "extra": {
        "installer-name": "scolta"
    }
}
